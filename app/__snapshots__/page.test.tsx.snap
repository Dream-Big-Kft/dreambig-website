                >
                  <div>
                    <label
                      class="text-sm font-medium text-foreground"
                      for="contact-name"
                    >
                      Name
                    </label>
                    <input
                      autocomplete="name"
                      class="mt-2 w-full rounded-md border border-border bg-background px-4 py-3 text-base text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/75 focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/25 dark:bg-card"
                      id="contact-name"
                      name="name"
                      placeholder="Your name"
                      required=""
                      type="text"
                    />
                  </div>
                  <div>
                    <label
                      class="text-sm font-medium text-foreground"
                      for="contact-email"
                    >
                      Email
                    </label>
                    <input
                      autocomplete="email"
                      class="mt-2 w-full rounded-md border border-border bg-background px-4 py-3 text-base text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/75 focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/25 dark:bg-card"
                      id="contact-email"
                      name="email"
                      placeholder="you@example.com"
                      required=""
                      type="email"
                    />
                  </div>
                </div>
                <div>
                  <label
                    class="text-sm font-medium text-foreground"
                    for="contact-phone"
                  >
                    Phone number 
                    <span
                      class="text-muted-foreground"
                    >
                      (optional)
                    </span>
                  </label>
                  <input
                    autocomplete="tel"
                    class="mt-2 w-full rounded-md border border-border bg-background px-4 py-3 text-base text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/75 focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/25 dark:bg-card"
                    id="contact-phone"
                    name="phone"
                    placeholder="+36 30 123 4567"
                    type="tel"
                  />
                </div>
                <div>
                  <label
                    class="text-sm font-medium text-foreground"
                    for="contact-message"
                  >
                    Message
                  </label>
                  <textarea
                    class="mt-2 w-full rounded-md border border-border bg-background px-4 py-3 text-base text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/75 focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/25 dark:bg-card min-h-36 resize-y"
                    id="contact-message"
                    name="message"
                    placeholder="What are you building, improving, or trying to solve?"
                    required=""
                    rows="4"
                  />
                </div>
                <div
                  class="flex flex-col items-start gap-3 sm:flex-row sm:items-center"
                >
                  <button
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-base transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive cursor-pointer bg-primary text-primary-foreground shadow-sm hover:bg-primary hover:shadow-[0_10px_24px_rgba(15,23,42,0.16)] active:shadow-sm h-10 rounded-md has-[>svg]:px-4 group px-8 font-medium"
                    data-slot="button"
                    type="submit"
                  >
                    Send Message
                    <svg
